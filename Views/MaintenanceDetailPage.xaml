<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:JCA.Mobile.ViewModels"
             xmlns:models="clr-namespace:JCA.Mobile.Models"
             x:Class="JCA.Mobile.Views.MaintenanceDetailPage"
             Title="Ticket Details"
             BackgroundColor="#F7F5F0">

    <ContentPage.BindingContext>
        <vm:MaintenanceDetailViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <ActivityIndicator IsRunning="{Binding IsBusy}" HorizontalOptions="Center" Color="#CC0000" />

            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                <Label Text="{Binding Ticket.Details}" FontSize="20" FontAttributes="Bold" Grid.Column="0" />
                <Label Text="{Binding Ticket.Priority}" TextColor="{Binding Ticket.PriorityColor}" 
                       FontAttributes="Bold" Grid.Column="1" HorizontalOptions="End" />
                
                <Label Text="{Binding Ticket.DateSubmitted, StringFormat='Submitted on {0:MM/dd/yyyy}'}" 
                       FontSize="12" TextColor="#9CA3AF" Grid.Row="1" />
            </Grid>

            <BoxView HeightRequest="1" Color="#E5E7EB" />

            <VerticalStackLayout Spacing="5">
                <Label Text="Location" FontAttributes="Bold" FontSize="14" />
                <Label Text="{Binding Ticket.Campus}" FontSize="16" />
                <Label Text="{Binding Ticket.Room}" FontSize="16" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Category" FontAttributes="Bold" FontSize="14" />
                <Label Text="{Binding Ticket.Category}" FontSize="16" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Status" FontAttributes="Bold" FontSize="14" />
                <Picker ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" 
                        BackgroundColor="White" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Admin Notes" FontAttributes="Bold" FontSize="14" />
                <Editor Text="{Binding AdminNotes}" HeightRequest="150" BackgroundColor="White" 
                        Placeholder="Enter notes here..." />
            </VerticalStackLayout>

            <Button Text="Save Changes" Command="{Binding SaveChangesCommand}" 
                    BackgroundColor="#CC0000" TextColor="White" FontSize="18" 
                    Padding="15" Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
