<Shell
    x:Class="JCA.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:JCA.Mobile.Views"
    Shell.FlyoutBehavior="Disabled"
    BackgroundColor="#CC0000">

    <TabBar>
        <Tab Title="Announcements">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" Route="MainPage" />
        </Tab>
        <Tab Title="Maintenance">
            <ShellContent ContentTemplate="{DataTemplate views:MaintenancePage}" Route="MaintenancePage" />
        </Tab>
    </TabBar>

</Shell>
